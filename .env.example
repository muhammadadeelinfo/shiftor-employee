# Copy this file to `.env` and set the real values before running Expo locally.
# Never commit secrets to version control.

# App runtime
API_BASE_URL=http://localhost:3000
EXPO_STAGE=production
EXPO_SCHEME=shiftoremployee
AUTH_REDIRECT_URL=shiftoremployee://auth/callback
ENABLE_LOCATION_IN_DEV=false
APP_VERSION=1.0.0

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_ANON_KEY
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=company-assets
SUPABASE_SERVICE_KEY=sb_secret_REPLACE_WITH_SERVICE_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_WITH_SERVICE_ROLE_KEY

# Database
DATABASE_URL="postgresql://postgres:REPLACE_WITH_DB_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:REPLACE_WITH_DB_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres?sslmode=require"

# Native app identifiers
IOS_BUNDLE_IDENTIFIER=com.shiftor.employee
IOS_BUILD_NUMBER=1
ANDROID_PACKAGE=com.shiftor.employee
ANDROID_VERSION_CODE=1

# Native permission copy
IOS_CAMERA_USAGE_DESCRIPTION=Camera access is required to scan QR codes for clock-in.
IOS_CALENDAR_USAGE_DESCRIPTION=Calendar access lets you import shifts and sync your schedule.
IOS_NOTIFICATIONS_USAGE_DESCRIPTION=Notifications keep you updated about shifts and schedule changes.

# Legal/support
LEGAL_PRIVACY_URL=https://goilabs.com/privacy?product=Shiftor%20Employee
LEGAL_TERMS_URL=https://goilabs.com/terms?product=Shiftor%20Employee
LEGAL_SUPPORT_URL=https://goilabs.com/support?product=Shiftor%20Employee

# Services
EAS_PROJECT_ID=8e784b57-2e18-4286-9468-532d043fd407
SENTRY_DSN=
